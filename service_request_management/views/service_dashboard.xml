<odoo>

    <record id="view_service_dashboard_form" model="ir.ui.view">
        <field name="name">service.dashboard.form</field>
        <field name="model">service.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <sheet>

                    <div class="oe_title">
                        <h1>Service Dashboard</h1>
                    </div>

                    <!-- ========================= -->
                    <!-- CARDS -->
                    <!-- ========================= -->
                   <div class="row">

				    <!-- TOTAL -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_requests"
				                class="o_dashboard_card bg-total">
				            <h2><field name="total_requests"/></h2>
				            <div>Total</div>
				        </button>
				    </div>
				
				    <!-- DRAFT -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_draft"
				                class="o_dashboard_card bg-draft">
				            <h2><field name="draft_count"/></h2>
				            <div>Draft</div>
				        </button>
				    </div>
				
				    <!-- ASSIGNED -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_assigned"
				                class="o_dashboard_card bg-assigned">
				            <h2><field name="assigned_count"/></h2>
				            <div>Assigned</div>
				        </button>
				    </div>
				
				    <!-- IN PROGRESS -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_progress"
				                class="o_dashboard_card bg-progress">
				            <h2><field name="progress_count"/></h2>
				            <div>In Progress</div>
				        </button>
				    </div>
				
				    <!-- DONE -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_done"
				                class="o_dashboard_card bg-done">
				            <h2><field name="done_count"/></h2>
				            <div>Done</div>
				        </button>
				    </div>
				
				    <!-- CANCEL -->
				    <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
				        <button type="object" name="action_open_cancel"
				                class="o_dashboard_card bg-cancel">
				            <h2><field name="cancel_count"/></h2>
				            <div>Cancelled</div>
				        </button>
				    </div>
				
				</div>
                    <!-- ========================= -->
                    <!-- METRICS -->
                    <!-- ========================= -->
                    <group col="3" class="mt16">
                        <group>
                            <field name="total_hours" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="completion_rate" readonly="1"/>
                        </group>
                    </group>

                    <!-- ========================= -->
                    <!-- RECENT -->
                    <!-- ========================= -->
                    <notebook>
                        <page string="Recent Requests">
                            <field name="recent_requests" mode="list" limit="5">
                                <list create="0">
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="user_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <!-- ========================= -->
                    <!-- BUTTONS -->
                    <!-- ========================= -->
                    <footer>
                        <button name="action_refresh"
                                type="object"
                                string="Refresh"
                                class="btn-primary"/>

                        <button name="action_create_request"
                                type="object"
                                string="New Request"
                                class="btn-secondary"/>
                    </footer>

                </sheet>
            </form>
        </field>
    </record>


 

