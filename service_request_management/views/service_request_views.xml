<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Service Request Tree View -->
    <record id="view_service_request_tree" model="ir.ui.view">
        <field name="name">service.request.tree</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <list decoration-success="state=='done'" decoration-danger="state=='cancelled'" decoration-info="state=='in_progress'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="scheduled_date"/>
                <field name="total_hours" sum="Total Hours"/>
                <field name="total_amount" sum="Total Amount" widget="monetary"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

     <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">service.request.form</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <form>
            

                <header>
                 <button name="action_assigned"
					        type="object"
					        string="Assigned"
					        class="btn-primary"
					        invisible="state != 'draft'"/>
					        
					        
					        
                   <button name="action_start"
					        type="object"
					        string="Start Work"
					        class="btn-primary"
					        invisible="state != 'assigned'"/>
					
					<button name="action_done"
					        type="object"
					        string="Mark as Done"
					        class="btn-primary"
					        invisible="state != 'in_progress'"/>
					        
					<button name="action_create_invoice"
					        type="object"
					        string="Create Bill"
					        class="btn-secondary"
					        invisible="state != 'done' or invoice_id"/>
					
					<button name="action_cancel"
					        type="object"
					        string="Cancel"
					        class="btn-secondary"
					        invisible="state in ['done', 'cancelled']"/>
					        
					<button name="action_open_assign_wizard"
				        string="Reassign"
				        type="object"
				        class="btn-primary"
				        invisible="state in ['draft','done', 'cancelled','in_progress']"/>
				        
				        
				        <button name="action_open_reschedule_wizard"
					        type="object"
					        string="Reschedule"
					        class="btn-warning"
					        invisible="state in ['draft','done', 'cancelled','in_progress']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,in_progress,done"/>
                </header>
                <sheet>
                <div class="oe_button_box" name="button_box">
				    <button name="action_view_invoice"
				            type="object"
				            class="oe_stat_button"
				            icon="fa-file-text-o"
				            invisible="not invoice_id">
				        <field name="invoice_count" widget="statinfo" string="Bill" />
				    </button>
				</div>
                
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" options="{'no_create': True}" required="1" readonly="state != 'draft'"/>
                            <field name="sale_order_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="user_id"  required="1" widget="many2one_avatar_user" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="scheduled_date" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    
                    
                   <group>
					  <field name="is_fleet_required"
					       readonly="state != 'draft'"/>
					
					<field name="fleet_id"
					       invisible="not is_fleet_required"
					       readonly="state != 'draft'"/>
					
					<field name="fleet_scheduled_date"
					       invisible="not is_fleet_required"
					       readonly="state != 'draft'"/>
					
					
					
					</group>


                    
                    <group>
                        <field name="description" placeholder="Add description and instructions..."/>
                    </group>

                    <notebook>
                        <page string="Timesheets" name="timesheets">
                            <field name="timesheet_ids" readonly="state == 'done'">
                                <!-- FIXED: Removed 'active_id' from context and used correct syntax -->
                                <list editable="bottom" decoration-success="amount>0">
                                    <field name="date"/>
                                    <field name="role"/>
                                    <field name="description"/>
                                    <field name="hours" sum="Total Hours"/>
                                    <field name="rate" widget="monetary"/>
                                    <field name="amount" widget="monetary" sum="Total Amount"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="date"/>
                                        <field name="role"/>
                                        <field name="hours"/>
                                        <field name="rate" widget="monetary"/>
                                        <field name="description"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Assign History">
						    <field name="assign_history_ids" readonly="1">
						        <list>
						            <field name="old_user_id"/>
						            <field name="new_user_id"/>
						            <field name="changed_by"/>
						            <field name="reason"/>
						            <field name="create_date" string="Change on"/>
						        </list>
						    </field>
						</page>
                    </notebook>
                </sheet>
               <chatter/>
            </form>
        </field>
    </record>


<record id="view_service_assign_wizard_form" model="ir.ui.view">
    <field name="name">service.assign.wizard.form</field>
    <field name="model">service.assign.wizard</field>
    <field name="arch" type="xml">
        <form string="Reassign User">
            <group>
                <field name="new_user_id" required="1"/>
                <field name="reason" required="1"/>
            </group>
            <footer>
                <button name="action_assign" type="object"
                        string="Assign" class="btn-primary"/>
                <button string="Cancel" special="cancel"/>
            </footer>
        </form>
    </field>
</record>




    <!-- Actions and Menus -->
    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Service Requests</field>
        <field name="res_model">service.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first service request!
            </p>
            <p>
                Service requests allow you to manage field service operations,
                assign employees, and track timesheets.
            </p>
        </field>
    </record>
    
    
    <!-- Menu Items -->
    <menuitem id="menu_service_request" 
              name="Service Requests" 
              parent="menu_script_management" 
              action="action_service_request" 
              sequence="1"/>
              
              
   
              
              
              
              
  <menuitem 
		id="menu_script_management" 
	    name="Service Management" 
	    action="om_emp_dashboard_client_action1" 
	    sequence="1"
	    web_icon="service_request_management,static/description/icon.png"  groups="group_service_user,group_service_manager,group_service_admin"/>
              
              
              
              
              
    
    
    
          
          
          



      
      
      
      
      
      

</odoo>