<odoo>

    <record id="group_service_user" model="res.groups">
        <field name="name">Service User</field>
    </record>

    <record id="group_service_manager" model="res.groups">
        <field name="name">Service Manager</field>
    </record>



 <record id="group_service_admin" model="res.groups">
        <field name="name">Service admin</field>
    </record>
    
    
    
<record id="service_request_user_rule" model="ir.rule">
    <field name="name">Service Request User Own</field>
    <field name="model_id" ref="model_service_request"/>
    <field name="domain_force">[('user_id', '=', user.id)]</field>
    <field name="groups" eval="[(4, ref('service_request_management.group_service_user'))]"/>
</record>



<record id="service_request_manager_rule" model="ir.rule">
    <field name="name">Service Request Manager</field>
    <field name="model_id" ref="model_service_request"/>
    <field name="domain_force">
        ['|', ('user_id', '=', user.id), ('user_id.employee_id.parent_id.user_id', '=', user.id)]
    </field>
    <field name="groups" eval="[(4, ref('service_request_management.group_service_manager'))]"/>
</record>



<record id="service_request_admin_rule" model="ir.rule">
    <field name="name">Service Request Admin Full Access</field>
    <field name="model_id" ref="model_service_request"/>
    <field name="domain_force">[(1, '=', 1)]</field>
    <field name="groups" eval="[(4, ref('service_request_management.group_service_admin'))]"/>
</record>




</odoo>